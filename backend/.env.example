# For local development with Docker:
# DATABASE_URL=postgres://grabapass_user:grabapass_password@localhost:5432/grabapass

# For Cloud Database (Neon, Supabase, Render, AWS RDS, etc.):
# Replace the URL below with your actual cloud connection string.
DATABASE_URL=postgres://[user]:[password]@[host]:[port]/[database]?sslmode=require

# JWT Secret for signing tokens - change this in production!
JWT_SECRET=super-secret-key-for-dev-only
